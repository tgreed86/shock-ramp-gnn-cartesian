{
  "seed": 1337,
  "device": "mps",
  "data": {
    "pt_path": "./cache/DMR_7_5_50__125x250.h5",
    "H": 1002,
    "W": 2002,
    "bbox": [0.0, 4.0, 0.0, 2.0],
    "window_size": 5,
    "stride": 1,
    "num_workers": 0
  },
  "features": {
    "use_columns": [0, 1, 2, 3, 4],
    "names": ["U", "V", "RHO", "P", "E"],
    "normalize": true,
    "normalization": {
      "momentum_sigma_mode": "independent"
    },
    "build": {
      "use_pos": true,
      "position_mode": "boundary_distances",
      "_comment_position_mode": "Options: 'xy' for raw node centers, 'boundary_distances' for [left,right,bottom,top] distances, or 'none'.",
      "boundary_distance_normalize": true,
      "boundary_distance_clip": null,
      "boundary_distance_clip_normalize": true,
      "include_signed_distance_to_ramp": false,
      "include_dt_hat": true,
      "include_ramp_angle": true,
      "_comment_include_ramp_angle": "If true, append ramp angle as one extra node feature. Inferred from ramp_angle_deg, metadata, or DMR_* filename fallback.",
      "ramp_angle_units": "radians",
      "ramp_angle_deg": null
    }
  },
  "split": {
    "by_file": false,
    "val_files": 6,
    "test_files": 6
  },
  "policy": {
    "refine_ratio": 2,
    "geometry_mode": "starting_mesh"
  },
  "loss": {
    "use_huber": false,
    "huber_delta": 0.05,
    "physics_inputs_enabled": false,
    "physics_backend": "dec",
    "advection_type": "euler",
    "parc_include_adv": false,
    "parc_include_diff": false,
    "adv_channels": ["U", "V", "RHO", "P", "E"],
    "diff_channels": ["RHO", "P", "E"],
    "adv_weight": 0.0,
    "diff_weight": 0.0,
    "euler_flux_scheme": "rusanov",
    "advection_reconstruction": "first_order",
    "euler_flux_pressure_source": "channel",
    "nu": 0.0,
    "blend_weight": 0.0,
    "residual_weight": 0.0,
    "rho_floor": 1e-6,
    "u_clip": 1000.0
  },
  "model": {
    "name": "fluxgraphnet",
    "type": "fluxgraphnet",
    "_comment_type": "Options: 'featurenet', 'sageconv', or 'meshgraphnet'. MeshGraphNet matches the 1D_advection/Burgers processor stack and uses edge_attr_channels (default 5).",
    "conv_type": "sage",
    "_comment_conv_type": "FeatureNet only: one of 'sage', 'gine', or 'nnconv'.",
    "hidden": 128,
    "layers": 3,
    "predict_type": "rate",
    "use_open_boundary_source": true,
    "open_boundary_mode": "none",
    "open_boundary_modes_by_side": {
      "left": "learned_source",
      "top": "learned_source",
      "right": "boundary_flux",
      "bottom": "none"
    },
    "open_boundary_flux_scale": 0.05,
    "open_boundary_flux_outflow_only": true,
    "open_boundary_flux_include_pressure": false,

    "use_ramp_boundary_source": false,
    "ramp_pressure_source_weight": 0.0
  },
  "train": {
    "epochs": 5,
    "batch_size": 1,
    "lr": 1e-4,
    "weight_decay": 0.0,
    "grad_clip": 1.0,
    "mesh_mode": "uniform",
    "precomp_force_recompute": false,
    "save_dir": "./runs_cartesian/125x250/no_physics/fluxgraphnet/test",
    "validation_every_epochs": 5,
    "checkpoint_every_epochs": 5,
    "norm_stats_progress": false,
    "norm_stats_progress_every": 10
  },
  "speed": {
    "amp": false,
    "interp_chunk": 4096,
    "knn_k": 8,
    "cache_interps": true
  },
  "scheduler": {
    "use": false,
    "mode": "min",
    "factor": 0.5,
    "patience": 5,
    "threshold": 0.001,
    "threshold_mode": "rel",
    "cooldown": 0,
    "min_lr": 1e-6
  },
  "debug": {
    "nan_watch": false,
    "print_batch_time": false,
    "print_runtime_mesh_batch_breakdown": false,
    "progress_every_batches": 10,
    "sync_runtime_timing": false
  }
}
