    "refine_ratio": 2,
    "dilate_cells_lmax": 3.0,
    "hysteresis_mode": "percentile",
    "hysteresis_prev_source": "predicted",
    "_comment_hysteresis_prev_source": "predicted or gt",
    "percentile_low": 85.0,
    "percentile_high": 95.0,
    "percentiles_by_level": {
      "selection": "per_level",
      "_comment_selection": "global or per_level (or auto)",
      "1": {
        "low": 84.0,
        "high": 93.0
      },
      "2": {
        "low": 89.0,
        "high": 95.0
      },
      "3": {
        "low": 93.0,
        "high": 96.0
      },
      "4": {
        "low": 96.0,
        "high": 97.0
      }
    },
    "combine": "l2",
    "grad_channels": [
      0,
      1,
      2,
      3
    ],
    "max_level": 3,
    "tau_low": 1.0,
    "tau_high": 1.0
  },

  "features": {
    "use_columns": [
      0,
      1,
      2,
      3
    ],
    "names": [
      "density",
      "x_momentum",
      "y_momentum",
      "energy"
    ],
    "normalize": true,
    "normalization": {
      "momentum_sigma_mode": "independent",
      "_comment_momentum_sigma_mode": "independent (per-channel std) or shared_rms (tie x/y momentum sigmas by RMS)."
    },
    "build": {
      "use_dt_hat_fixed": false,
      "_comment_use_dt_hat_fixed": "If true, append normalized dt_hat = dt_phys/dt_ref as one extra node feature."
    }
  },

  "model": {
    "name": "FeatureNet",
    "hidden": 128,
    "layers": 4,
    "dropout": 0.1,
    "predict_type": "rate",
    "_comment_predict_type": "absolute, delta, or rate",
    "use_skip": true,
    "skip_type": "block",
    "use_layernorm": true,
    "layernorm_eps": 1e-6,
    "use_attention": true,
    "attention": {
      "replace_last_layer": true,
      "heads": 4,
      "dropout": 0.0,
      "use_edge_attr": true,
      "edge_dim": 5
    }
  },

  "loss": {
    "use_huber": false,
    "huber_delta": 0.05,
    "interp_type": "standard",
    "interp_k": 8,
    "laplacian_weight": 0.0,
    "temporal_weight": 0.0,
    "dec": true,
    "parc": true,
    "parc_detach_inputs": true,
    "physics_backend": "dec",
    "_comment_physics_backend": "dec (default) or mls (moving least squares)",

    "mls_ops_device": "cpu",
    "mls_use_2hop_extension": false,
    "mls_use_neighbor_damping": true,
    "mls_damping_alpha": 0.5,
    "mls_poly_order": 2,
    "mls_min_neighbors": 6,
    "mls_cache_by_geometry": false,

    "parc_include_diff": true,
    "diff_channels": [
      "density",
      "energy"
    ],
    "diff_weight": 1.0,

    "parc_include_adv": true,
    "advection_type": "euler",
    "euler_flux_scheme": "rusanov",
    "advection_reconstruction": "first_order",
    "_comment_advection_reconstruction": "first_order (default) or muscl (second order)",
    "muscl_limiter": "minmod",
    "_comment_muscl_limiter": "minmod, mc, or vanleer (used when advection_reconstruction=muscl)",
    "gamma": 1.4,
    "p_floor": 0.0,
    "adv_channels": [
      "density",
      "x_momentum",
      "y_momentum",
      "energy"
    ],
    "adv_weight": 1.0,
    "adv_all_steps": true,

    "nu": 0.0001,
    "blend_weight": 0.0,
    "residual_weight": 0.0,

    "rho_floor": 1e-6,
    "u_clip": 1000.0,

    "parc_use_adapter": false,
    "parc_feat_norm": false,
    "parc_feat_clip_pre": 0.0,
    "parc_feat_clip_post": 0.0,
    "parc_feat_norm_momentum": 0.02,
    "parc_gate_init": -3.0,
    "parc_gate_per_channel": false,

    "ops_term_clip": 0.0,
    "state_rho_max": 0.0,
    "state_E_max": 0.0,
    "state_m_max": 0.0,
    "ops_rho_max": 0.0,
    "ops_E_max": 0.0,
    "ops_m_max": 0.0
