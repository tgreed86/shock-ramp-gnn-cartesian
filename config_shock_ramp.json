      "refine_only": true,
      "max_cells_per_step": 1000000,
      "policy_backend": "gradient_fast",
      "cnn": {
        "checkpoint_path": "./runs_mesh_policy_cnn/without_parent_masks/unet_hierarchical/max_level_3/predict_next_ts/500ep_lr-scheduler_predict-next-ts_3-29-26/mesh_policy_cnn_last.pt",
        "include_parent_mask": false,
        "include_coords": true,
        "include_dt": true,
        "dt_channel_mode": "dt_hat",
        "use_saved_thresholds": true,
        "threshold_default": 0.5,
        "threshold_by_level": {},
        "device": "same"
      },
      "step_log": {
        "enabled": true,
        "path": "./runs_mesh_first/runtime_step_log.csv",
        "append": false
      },
      "mesh_plot": {
        "enabled": false,
        "plot_predictor_inputs": false,
        "plot_gt_features": false,
        "out_dir": "./runs_mesh_first/runtime_mesh_plots",
        "split": "train",
        "_comment_split": "train, eval, or both",
        "every_rebuilds": 1,
        "max_plots": 20,
