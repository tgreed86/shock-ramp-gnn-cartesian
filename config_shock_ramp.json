    "mesh_mode": "predicted",
    "_comment_mesh_mode": "predicted or uniform",
    "runtime_mesh": {
      "enabled": true,
      "domain_mode": "wedge_lookup",
      "_comment_domain_mode": "starting_mesh resets to starting mesh every step for runtime CNN parity with training target semantics.",
      "warm_start_from_precompute": false,
      "update_every_steps": 1,
      "detach_policy_input": true,
