{
  "seed": 1337,
  "device": "mps",

  "data": {
    "pt_path": "/Users/trevorreed/UVA_postdoc_stuff/gparc/data/shock_ramp/shock_ramp_amr.pt",
    "H": 64,
    "W": 64,
    "L_max": 3,
    "bbox": [
