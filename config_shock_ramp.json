{
  "seed": 1337,
  "device": "mps",

  "data": {
    "pt_path": "/Users/trevorreed/UVA_postdoc_stuff/gparc/data/shock_ramp/shock_ramp_amr.pt",
    "H": 64,
    "W": 64,
    "L_max": 3,
    "bbox": [0.0, 1.0, 0.0, 1.0],
    "pre_train_dir": "./precomp_cache",
    "window_size": 5,
    "stride": 1,
    "num_workers": 0
  },

  "features": {
    "use_columns": [0, 1, 2, 3],
    "names": ["density", "x_momentum", "y_momentum", "energy"],
    "normalize": true
  },

  "split": { "train": 0.85, "val": 0.1, "test": 0.05 },

  "train": {
    "precomp_cache_path": "./cache/all/shock_ramp_precomp_pLow85_pHigh95_faceAdj_DEC.h5",
    "precomp_force_recompute": true,
    "epochs": 10,
    "validation_every_epochs": 1,
    "batch_size": 1,
    "lr": 0.0001,
    "weight_decay": 0.0,
    "grad_clip": 0.5,
    "rate_clip_norm": 50.0,
    "delta_clip_norm": 5.0,
    "interp_type": "standard", 
    "_comment_interp_type": "overlay or knn",
    "overlay_fill": "value",  
    "_comment_interp_type": "value or none",
    "overlay_fill_value": 0.0,
    "knn_k": 8,
    "mesh_mode": "predicted",
    "save_dir": "./runs_mesh_first",
    "multi_step_K": 2,
    "uniform_H": 256,
    "uniform_W": 256,
    "time_integrator": "euler",
    "rk4_start_epoch": 10,
    "rk4_ramp_epochs": 5,
    "teacher_forcing_uniform": false,
    "uniform_diag_edges": false,
    "validation_every_epochs": 5,
    "runtime_mesh": {
      "enabled": true,
      "warm_start_from_precompute": false,
      "update_every_steps": 2,
      "detach_policy_input": true,
      "reset_to_coarse_each_step": true,
      "refine_only": true,
      "max_cells_per_step": 500000,
      "policy_backend": "cnn",
      "cnn": {
        "checkpoint_path": "./runs_mesh_policy_cnn/without_parent_masks/unet_hierarchical/500ep_lr-scheduler_3-6-26/mesh_policy_cnn_last.pt",
        "include_parent_mask": false,
        "include_coords": true,
        "threshold_default": 0.5,
        "threshold_by_level": {},
        "device": "same"
      },
      "step_log": {
        "enabled": true,
        "path": "./runs_mesh_first/runtime_step_log.csv",
        "append": false
      }
    }
  },

  "edges": {
    "method": "face",
    "_comment_method": "face (for face-adjacency) or knn",
    "knn_k": 8
  },

  "scheduler": {
    "use": false,
    "mode": "min",
    "factor": 0.5,
    "patience": 5,
    "threshold": 0.001,
    "threshold_mode": "rel",
    "cooldown": 0,
    "min_lr": 0.000001,
    "verbose": true
  },

  "policy": {
    "geometry_mode": "gt_gradients",
    "_comment_geometry_mode": "gt_gradients or starting_refine for uniform mesh",
    "starting_refine_to_level": 0,
    "refine_ratio": 2,
    "hysteresis_mode": "percentile",
    "percentile_low":  85.0,
    "percentile_high": 95.0,
    "percentiles_by_level": {
      "selection": "global",
      "_comment_selection": "global or per_level (or auto)",
      "1": {"low": 100.0, "high": 100.0},
      "2": {"low": 100.0, "high": 100.0},
      "3": {"low": 100.0, "high": 100.0}
    },
    "combine": "l2",
    "grad_channels": [0],
    "grad_norm": "l2",
    "max_level": 3,
    "tau_low":  1.0,
    "tau_high": 1.0
  },

  "loss": {
    "use_huber": false,
    "huber_delta": 0.05,
    "interp_type": "standard",
    "interp_k": 8,
    "primary_weight": 1.0,
    "laplacian_weight": 0.0,
    "temporal_weight": 0.0,
    "dec": true,
    "parc": true,
    "parc_detach_inputs": true,
    "physics_backend": "dec",
    "_comment_physics_backend": "dec (default) or mls (moving least squares)",

    "mls_ops_device": "cpu",
    "mls_use_2hop_extension": false,
    "mls_use_neighbor_damping": true,
    "mls_damping_alpha": 0.5,
    "mls_poly_order": 2,
    "mls_min_neighbors": 6,
    "mls_cache_by_geometry": false,
    "mls_scale_by_dt": false,
    
    "parc_include_diff": true,
    "diff_channels": ["density", "energy"],
    "diff_weight": 1.0,

    "parc_include_adv": true,
    "advection_type": "euler",
    "euler_flux_scheme": "rusanov",
    "advection_reconstruction": "first_order",
    "_comment_advection_reconstruction": "first_order (default) or muscl (second order)",
    "muscl_limiter": "minmod",
    "_comment_muscl_limiter": "minmod, mc, or vanleer (used when advection_reconstruction=muscl)",
    "gamma": 1.4,
    "p_floor": 0.0,
    "adv_channels": ["density", "x_momentum", "y_momentum", "energy"],
    "adv_weight": 1.0,
    "adv_all_steps": true,
  
    "nu": 0.0001,

    "blend_weight": 0.0,
    "residual_weight": 0.0,

    "rho_floor": 1e-6,
    "u_clip": 1000.0,

    "parc_use_adapter": false,
    "parc_feat_norm": false,
    "parc_feat_clip_pre": 50.0,
    "parc_feat_clip_post": 10.0,
    "parc_feat_norm_momentum": 0.02,
    "parc_gate_init": -3.0,
    "parc_gate_per_channel": false,

    "ops_term_clip": 0.0,
    "state_rho_max": 0.0,
    "state_E_max": 0.0,
    "state_m_max": 0.0,
    "ops_rho_max": 0.0,
    "ops_E_max": 0.0,
    "ops_m_max": 0.0
  },

  "eval": {
    "checkpoint": "./runs_mesh_first/best.pt",
    "qual_pdf": "./qual_rollout.pdf",
    "fine_L": 3,
    "show_mesh": true
  },

  "mesh": {
    "starting_mesh_path": "./utils/wedge_mesh_spec.pt"
  },

  "model": {
    "name": "FeatureNet",
    "hidden": 128,
    "layers": 3,
    "dropout": 0.1,
    "predict_type": "rate",
    "_comment_predict_type": "absolute, delta, or rate"
  },

  "debug": {
    "plot_gradients": false,
    "profile": false,
    "plot_precomp_max_cells":  "250_000",
    "plot_precomp_linewidth": 0.05,
    "print_dec_checks": false,
    "print_loss_components": false,
    "nan_watch": false,
    "nan_first_only": false,
    "dbg_dec_ops": false,
    "budget_watch": true,
    "run_stepA": false,
    "stepA_k": 0,
    "stepA_star": false,
    "stepA_star_kmin": 5,
    "stepA_teacher": false,
    "stepA_u_max": 1000.0,
    "drift_watch": false,
    "oracle_watch": false,
    "fast_next_diag": false,
    "parc_scale_watch": false,
    "print_norm_sanity_once": false,
    "teacher_force_ops": false,
    "hang_watch_batches": 1000,
    "print_batch_time": true,
    "print_runtime_mesh_batch_breakdown": true
  },

  "speed": {
    "interp_chunk": 4096
  },
  "idw": {
    "backend": "faiss_ivf",
    "faiss_nlist": 512,
    "faiss_nprobe": 32,
    "allow_fallback_to_exact": true
  }
}
