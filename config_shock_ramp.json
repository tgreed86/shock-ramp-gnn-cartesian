        "enabled": true,
        "directory": "./cache/first_simulation/64by64-coarse/uniform_mesh/",
        "level_files": {},
        "fallback_to_idw": true,
        "max_cached_feature_steps": 16
      }
    },

    "epochs": 1,
    "checkpoint_every_epochs": 5,
    "validation_every_epochs": 5,
    "batch_size": 1,
    "lr": 0.0001,
    "weight_decay": 0.0,
    "grad_clip": 0.5,
    "rate_clip_norm": 50.0,
    "delta_clip_norm": 5.0,
    "interp_type": "standard",
    "_comment_interp_type": "standard or knn",
    "knn_k": 8,
    "time_integrator": "euler",
    "rk4_start_epoch": 10,
    "rk4_ramp_epochs": 5,
