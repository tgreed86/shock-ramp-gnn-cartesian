{
  "seed": 1337,
  "device": "mps",

  "data": {
    "pt_path": "/Users/trevorreed/UVA_postdoc_stuff/gparc/data/shock_tube/level_3/amr_cells_L3.pt",
    "H": 64,
    "W": 64,
    "L_max": 2,
    "bbox": [0.0, 1.0, 0.0, 1.0],
    "pre_train_dir": "./precomp_cache",
    "window_size": 4,
    "stride": 1,
    "num_workers": 0
  },

  "features": {
    "use_columns": [0, 1, 3],
    "names": ["density", "x_momentum", "energy"],
    "normalize": true,
    "normalization": {
      "momentum_sigma_mode": "independent",
      "_comment_momentum_sigma_mode": "independent (per-channel std) or shared_rms (tie x/y momentum sigmas by RMS)."
    },
    "build": {
      "use_dt_hat_fixed": false,
      "_comment_use_dt_hat_fixed": "If true, append normalized dt_hat = dt_phys/dt_ref as one extra node feature."
    }
  },

  "split": { "train": 0.8, "val": 0.1, "test": 0.1 },

  "train": {
    "precompute_t_start": null,
    "precompute_t_end": null,
    "_comment_precompute_t_range": "Optional inclusive raw-snapshot range [start,end] used before windowing/precompute/training. Need at least 2 snapshots (e.g., 50..51 for one transition).",
    "epochs": 1,
    "batch_size": 1,
    "lr": 0.001,
    "weight_decay": 0.0,
    "grad_clip": 1.0,
    "interp_type": "standard", 
    "_comment_interp_type": "overlay or knn",
    "overlay_fill": "value",  
    "_comment_interp_type": "value or none",
    "overlay_fill_value": 0.0,
    "knn_k": 8,
    "mesh_mode": "predicted",
    "save_dir": "./runs_mesh_first",
    "multi_step_K": 2
  },

  "scheduler": {
    "use": true,
    "mode": "min",
    "factor": 0.5,
    "patience": 5,
    "threshold": 0.0001,
    "threshold_mode": "rel",
    "cooldown": 0,
    "min_lr": 0.000001,
    "verbose": true
  },

  "policy": {
    "mode": "gradient",
    "hysteresis": true,
    "hysteresis_mode": "percentile",
    "percentile_low":  60.0,
    "percentile_high": 80.0,
    "percentiles_by_level": {
    "1": {"low": 50.0, "high": 80.0},
    "2": {"low": 50.0, "high": 80.0},
    "3": {"low": 85.0, "high": 95.0}
    },
    "combine": "l2",
    "grad_channels": [0, 1, 3],
    "grad_norm": "l2",
    "max_level": 3,
    "tau_low":  1.0,
    "tau_high": 1.0
  },

  "loss": {
    "use_huber": true,
    "huber_delta": 0.05,
    "interp_type": "standard",
    "interp_k": 8,
    "primary_weight": 1.0,
    "laplacian_weight": 0.0,
    "temporal_weight": 0.0
  },

  "eval": {
    "checkpoint": "./runs_mesh_first/best.pt",
    "qual_pdf": "./qual_rollout.pdf",
    "fine_L": 2,
    "show_mesh": true
  },

  "model": {
    "name": "FeatureNet",
    "predict_delta": true
  },
  "debug": {
    "plot_gradients": true,
    "profile": false
  },
  "speed": {
    "interp_chunk": 4096
  }
}
